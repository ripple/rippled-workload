FROM ghcr.io/astral-sh/uv:0.9-python3.13-trixie

ENV PYTHONUNBUFFERED=1 \
    PATH="/workload/.venv/bin:$PATH"

WORKDIR /workload

RUN apt-get update && apt-get install -y curl vim-tiny jq

COPY workload/pyproject.toml workload/uv.lock /workload/

COPY workload /workload

RUN --mount=type=cache,target=/root/.cache/uv uv sync --frozen

COPY test_composer/all_transactions /workload/all_transactions

EXPOSE 8000

CMD ["uvicorn", "workload_app.main:app", "--host", "0.0.0.0", "--port", "8000"]
